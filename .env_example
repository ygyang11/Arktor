# ============================================================
# Arktor — Example Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your values.
# .env is git-ignored and will NOT be committed.
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Search API Keys ---
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- PDF Parsing API Keys ---
MINERU_API_KEY=
PADDLEOCR_API_KEY=

# --- Academic Paper API Keys ---
SEMANTIC_SCHOLAR_API_KEY=

# --- Arktor LLM Configuration (optional, overrides config.yaml) ---
# ARKTOR_LLM_PROVIDER=openai
# ARKTOR_LLM_MODEL=gpt-4o
# ARKTOR_LLM_TEMPERATURE=0.7
# ARKTOR_LLM_MAX_TOKENS=4096
# ARKTOR_LLM_BASE_URL=

# --- Arktor General ---
# ARKTOR_VERBOSE=false
# ARKTOR_TRACING_ENABLED=true
